# =============================================================================
# SOUNDTRACKER - Variables de Entorno
# =============================================================================
# Copia este archivo a .env y rellena con tus valores
# cp .env.example .env

# -----------------------------------------------------------------------------
# APIs OBLIGATORIAS
# -----------------------------------------------------------------------------

# TMDB (The Movie Database) - https://www.themoviedb.org/settings/api
TMDB_API_KEY=tu_clave_tmdb_aqui

# Perplexity (búsqueda) - https://www.perplexity.ai/settings/api
PPLX_API_KEY=tu_clave_perplexity_aqui
PPLX_MODEL=sonar

# OpenAI - https://platform.openai.com/api-keys
OPENAI_API_KEY=tu_clave_openai_aqui
OPENAI_MODEL=gpt-5.1-mini

# Gemini (Google AI Studio) - https://aistudio.google.com/app/apikey
GEMINI_API_KEY=tu_clave_gemini_aqui
GEMINI_MODEL=gemini-2.5-flash

# -----------------------------------------------------------------------------
# APIs OPCIONALES
# -----------------------------------------------------------------------------

# YouTube Data API - https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=tu_clave_youtube_aqui

# Spotify - https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=tu_client_id_spotify
SPOTIFY_CLIENT_SECRET=tu_client_secret_spotify

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE COMPORTAMIENTO
# -----------------------------------------------------------------------------

# Descargar pósters localmente (1=sí, 0=no)
DOWNLOAD_POSTERS=1

# Habilitar búsqueda web (1=sí, 0=no)
SEARCH_WEB_ENABLED=1

# Habilitar deep research con Perplexity (1=sí, 0=no)
DEEP_RESEARCH_ENABLED=1

# Workers concurrentes para descarga de pósters
POSTER_WORKERS=8

# Límite de pósters por compositor (0=ilimitado)
POSTER_LIMIT=0

# Límite de películas por compositor
FILM_LIMIT=200

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE TOP 10
# -----------------------------------------------------------------------------

# Mínimo de votos en TMDB para considerar en Top 10
TOP_MIN_VOTE_COUNT=50

# Forzar películas premiadas en Top 10 (1=sí, 0=no)
TOP_FORCE_AWARDS=1

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE TEXTO
# -----------------------------------------------------------------------------

# Número de fuentes externas a buscar
EXTERNAL_SNIPPET_SOURCES=12

# Máximo de caracteres por snippet
EXTERNAL_SNIPPET_MAX_CHARS=700

# Máximo de párrafos en biografía
MAX_BIO_PARAGRAPHS=6

# Longitud mínima de párrafo
MIN_PARAGRAPH_LEN=50

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE BATCH
# -----------------------------------------------------------------------------

# Índice para reanudar procesamiento (1=desde el inicio)
START_INDEX=1

# -----------------------------------------------------------------------------
# CONFIGURACIÓN DE DESARROLLO
# -----------------------------------------------------------------------------

# Nivel de logging (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Modo debug (1=sí, 0=no)
DEBUG=0
